# ==================== Void System 后端配置模板 ====================
# 复制此文件为 void-system-backend/.env 并填写实际值（与 main.py 同目录）。
# cp .env.example .env
#
# 说明：后端会从 main.py 所在目录加载 .env，与你在哪个文件夹执行 uvicorn 无关。

# ==================== AI 模型配置 ====================

# ---------- 主选：全本地 Ollama（LLM 与嵌入均走本机；需运行 ollama）----------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=hf.co/unsloth/Qwen3-14B-GGUF:Q4_K_M
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=hf.co/Qwen/Qwen3-Embedding-4B-GGUF:Q8_0

# ---------- 已移除：HuggingFace 本地嵌入 ----------
# 相关依赖（langchain-huggingface / sentence-transformers / torch）已从项目移除。
# 如需恢复，请重新添加依赖并恢复对应配置。

# ---------- 可选：DeepSeek + Ollama 嵌入（本机必须运行 Ollama）----------
# LLM_PROVIDER=deepseek
# CHAT_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_MODEL=hf.co/Qwen/Qwen3-Embedding-4B-GGUF:Q8_0

# -------- OpenAI 官方 API --------
# LLM_PROVIDER=openai
# CHAT_MODEL=gpt-4o
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# -------- Google Gemini API --------
# LLM_PROVIDER=gemini
# CHAT_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------- 兼容 OpenAI 协议的第三方 API --------
# 月之暗面 Moonshot:
# LLM_PROVIDER=openai_compat
# CHAT_MODEL=moonshot-v1-128k
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
#
# 通义千问:
# LLM_PROVIDER=openai_compat
# CHAT_MODEL=qwen-max
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 认证配置 ====================
# JWT 密钥（生产环境必须修改！）
# SECRET_KEY=your-super-secret-random-key-minimum-32-characters

# ==================== 数据库配置 ====================
# DATABASE_URL=sqlite:///void_system.db
