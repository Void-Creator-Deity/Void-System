# Void System backend configuration
# Copy this file to .env and replace example values before deployment.

# Runtime
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
DEBUG=true
RELOAD=false
LOG_LEVEL=INFO

# Storage
DATABASE_URL=sqlite:///void_system.db
USER_FILES_DIR=user_files
CHROMA_PERSIST_DIR=chroma_db

# Authentication
# Set a unique random value with at least 32 characters in production.
SECRET_KEY=replace-with-a-unique-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Browser access
# Use only explicit front-end origins in production; never use *.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bootstrap accounts and test routes are opt-in.
BOOTSTRAP_ADMIN_ENABLED=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
ENABLE_TEST_USER_ENDPOINT=false

# AI and knowledge engine
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=hf.co/unsloth/Qwen3-14B-GGUF:Q4_K_M
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=hf.co/Qwen/Qwen3-Embedding-4B-GGUF:Q8_0
OPENAI_API_KEY=
OPENAI_BASE_URL=
GOOGLE_API_KEY=

# Optional local integration test (do not replace the normal default with this).
# LLM_PROVIDER=lmstudio
# CHAT_MODEL=google/gemma-4-12b-qat
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Legacy LangServe endpoints are disabled unless explicitly needed.
ENABLE_LANGSERVE_ROUTES=false
